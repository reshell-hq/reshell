{
  "name": "reshell",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cf:build": "opennextjs-cloudflare build && node scripts/patch-opennext-worker.mjs",
    "preview": "npm run cf:build && opennextjs-cloudflare preview",
    "deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "xo",
    "verify:surface-boundaries": "vitest run src/routing/surface-boundaries.test.ts",
    "generate:icons": "node scripts/generate-icons.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tanstack/react-query": "^5.80.7",
    "framer-motion": "^12.16.0",
    "idb": "^8.0.3",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "yaml": "^2.9.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.4",
    "prettier": "^3.8.4",
    "semantic-release": "^24.2.9",
    "sharp": "^0.35.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1",
    "wrangler": "^4.99.0",
    "xo": "^2.0.2"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "*.{js,ts,tsx}": "xo"
  }
}
